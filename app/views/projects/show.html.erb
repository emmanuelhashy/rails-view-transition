<% content_for :title, "#{@project.title} - Morphing Portfolio" %>

<div class="min-h-screen gradient-bg">
  <!-- Navigation Bar -->
  <nav class="navbar fixed top-0 left-0 right-0 z-50 glass-morphism">
    <div class="container mx-auto px-6 py-4">
      <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-white">Morphing Portfolio</h1>
        <div class="space-x-4">
          <%= link_to "← Back to Projects", projects_path, class: "text-white hover:text-blue-200 transition-colors" %>
          <a href="#about" class="text-white hover:text-blue-200 transition-colors">About</a>
          <a href="#contact" class="text-white hover:text-blue-200 transition-colors">Contact</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Project Hero Section -->
  <section class="project-detail-hero pt-32 pb-20">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center">
        <div class="mb-8">
          <span class="project-category px-4 py-2 bg-yellow-400 text-purple-800 rounded-full text-sm font-semibold"
                style="--project-id: project-<%= @project.id %>">
            <%= @project.category %>
          </span>
        </div>
        <h1 class="project-title text-5xl font-bold text-white mb-6 floating" style="--project-id: project-<%= @project.id %>">
          <%= @project.title %>
        </h1>
        <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
          <%= @project.description %>
        </p>
      </div>
    </div>
  </section>

  <!-- Project Content -->
  <section class="project-detail-content pb-20">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto">
        <!-- Project Image/Visual -->
        <div class="mb-12">
          <div class="project-image aspect-video bg-gradient-to-br from-blue-400 to-purple-500 rounded-2xl flex items-center justify-center glass-morphism"
               style="--project-id: project-<%= @project.id %>">
            <span class="text-8xl">🎨</span>
          </div>
        </div>

        <!-- Project Details -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          <!-- Main Content -->
          <div class="lg:col-span-2">
            <div class="glass-morphism rounded-2xl p-8 text-white">
              <h2 class="text-3xl font-bold mb-6">Project Overview</h2>
              <div class="prose prose-invert max-w-none">
                <p class="text-blue-100 text-lg leading-relaxed mb-6">
                  <%= @project.description %>
                </p>
                <p class="text-blue-100 text-lg leading-relaxed">
                  This project demonstrates the incredible power of modern web technologies, 
                  combining seamless user experiences with cutting-edge design principles. 
                  The morphing transitions create a fluid, engaging interface that keeps 
                  users captivated while they explore the content.
                </p>
              </div>
            </div>
          </div>

          <!-- Sidebar -->
          <div class="space-y-6">
            <!-- Project Info -->
            <div class="glass-morphism rounded-2xl p-6 text-white">
              <h3 class="text-xl font-bold mb-4">Project Details</h3>
              <div class="space-y-3">
                <div>
                  <span class="text-blue-200 text-sm">Category:</span>
                  <span class="block font-semibold"><%= @project.category %></span>
                </div>
                <div>
                  <span class="text-blue-200 text-sm">Status:</span>
                  <span class="block font-semibold text-green-400">Completed</span>
                </div>
                <div>
                  <span class="text-blue-200 text-sm">Featured:</span>
                  <span class="block font-semibold">
                    <%= @project.featured? ? "⭐ Yes" : "No" %>
                  </span>
                </div>
              </div>
            </div>

            <!-- Technologies -->
            <div class="glass-morphism rounded-2xl p-6 text-white">
              <h3 class="text-xl font-bold mb-4">Technologies</h3>
              <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 bg-blue-500 bg-opacity-50 rounded text-sm">Rails</span>
                <span class="px-3 py-1 bg-blue-500 bg-opacity-50 rounded text-sm">Turbo 8</span>
                <span class="px-3 py-1 bg-blue-500 bg-opacity-50 rounded text-sm">View Transitions</span>
                <span class="px-3 py-1 bg-blue-500 bg-opacity-50 rounded text-sm">Tailwind CSS</span>
                <span class="px-3 py-1 bg-blue-500 bg-opacity-50 rounded text-sm">JavaScript</span>
              </div>
            </div>

            <!-- Actions -->
            <div class="glass-morphism rounded-2xl p-6 text-white">
              <h3 class="text-xl font-bold mb-4">Actions</h3>
              <div class="space-y-3">
                <button class="w-full px-4 py-2 bg-white text-purple-600 rounded-lg font-semibold hover:scale-105 transition-transform">
                  View Live Demo
                </button>
                <button class="w-full px-4 py-2 border-2 border-white text-white rounded-lg font-semibold hover:bg-white hover:text-purple-600 transition-all">
                  View Source Code
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Projects -->
  <% if @related_projects.any? %>
    <section class="pb-20">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl font-bold text-white text-center mb-12">Related Projects</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <% @related_projects.each do |project| %>
            <div class="project-card glass-morphism rounded-xl p-4 text-white hover:scale-105 transition-all duration-300 cursor-pointer"
                 style="--project-id: project-<%= project.id %>"
                 data-turbo-frame="_top">
              <%= link_to project_path(project), class: "block" do %>
                <div class="aspect-square bg-gradient-to-br from-green-400 to-blue-500 rounded-lg mb-3 flex items-center justify-center">
                  <span class="text-2xl">✨</span>
                </div>
                <h3 class="font-bold mb-1"><%= project.title %></h3>
                <p class="text-blue-100 text-xs mb-2"><%= truncate(project.description, length: 60) %></p>
                <span class="px-2 py-1 bg-blue-500 bg-opacity-50 rounded text-xs">
                  <%= project.category %>
                </span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>
</div>
