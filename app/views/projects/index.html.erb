<% content_for :title, "Morphing Portfolio - Creative Projects" %>

<div class="min-h-screen gradient-bg">
  <!-- Navigation Bar -->
  <nav class="navbar fixed top-0 left-0 right-0 z-50 glass-morphism">
    <div class="container mx-auto px-6 py-4">
      <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-white">Morphing Portfolio</h1>
        <div class="space-x-4">
          <a href="#projects" class="text-white hover:text-blue-200 transition-colors">Projects</a>
          <a href="#about" class="text-white hover:text-blue-200 transition-colors">About</a>
          <a href="#contact" class="text-white hover:text-blue-200 transition-colors">Contact</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero-section pt-32 pb-20">
    <div class="container mx-auto px-6 text-center">
      <h1 class="text-6xl font-bold text-white mb-6 floating">
        Creative <span class="text-yellow-300">Morphing</span> Portfolio
      </h1>
      <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Experience the future of web design with seamless view transitions and morphing animations
      </p>
      <div class="flex justify-center space-x-4">
        <button class="px-8 py-3 bg-white text-purple-600 rounded-full font-semibold hover:scale-105 transition-transform pulse-glow">
          Explore Projects
        </button>
        <button class="px-8 py-3 border-2 border-white text-white rounded-full font-semibold hover:bg-white hover:text-purple-600 transition-all">
          Learn More
        </button>
      </div>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="category-filter mb-12">
    <div class="container mx-auto px-6">
      <div class="flex justify-center space-x-4 mb-8">
        <button class="px-6 py-2 bg-white bg-opacity-20 text-white rounded-full hover:bg-opacity-30 transition-all">
          All Projects
        </button>
        <% @categories.each do |category| %>
          <button class="px-6 py-2 bg-white bg-opacity-20 text-white rounded-full hover:bg-opacity-30 transition-all">
            <%= category %>
          </button>
        <% end %>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <% if @featured_projects.any? %>
    <section class="mb-16">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl font-bold text-white text-center mb-12">Featured Projects</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <% @featured_projects.each do |project| %>
            <div class="featured-project project-card glass-morphism rounded-2xl p-6 text-white hover:scale-105 transition-all duration-300 cursor-pointer"
                 style="--project-id: project-<%= project.id %>"
                 data-turbo-frame="_top">
              <%= link_to project_path(project), class: "block" do %>
                <div class="aspect-video bg-gradient-to-br from-blue-400 to-purple-500 rounded-xl mb-4 flex items-center justify-center">
                  <span class="text-4xl">🎨</span>
                </div>
                <h3 class="text-xl font-bold mb-2"><%= project.title %></h3>
                <p class="text-blue-100 text-sm mb-4"><%= truncate(project.description, length: 100) %></p>
                <div class="flex justify-between items-center">
                  <span class="px-3 py-1 bg-yellow-400 text-purple-800 rounded-full text-xs font-semibold">
                    <%= project.category %>
                  </span>
                  <span class="text-blue-200 text-sm">→</span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <!-- All Projects Grid -->
  <section id="projects" class="pb-20">
    <div class="container mx-auto px-6">
      <h2 class="text-3xl font-bold text-white text-center mb-12">All Projects</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <% @projects.each do |project| %>
          <div class="project-card glass-morphism rounded-xl p-4 text-white hover:scale-105 transition-all duration-300 cursor-pointer"
               style="--project-id: project-<%= project.id %>"
               data-turbo-frame="_top">
            <%= link_to project_path(project), class: "block" do %>
              <div class="aspect-square bg-gradient-to-br from-green-400 to-blue-500 rounded-lg mb-3 flex items-center justify-center">
                <span class="text-2xl">✨</span>
              </div>
              <h3 class="font-bold mb-1"><%= project.title %></h3>
              <p class="text-blue-100 text-xs mb-2"><%= truncate(project.description, length: 60) %></p>
              <span class="px-2 py-1 bg-blue-500 bg-opacity-50 rounded text-xs">
                <%= project.category %>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-20">
    <div class="container mx-auto px-6 text-center">
      <h2 class="text-4xl font-bold text-white mb-8">About This Demo</h2>
      <p class="text-xl text-blue-100 max-w-3xl mx-auto">
        This portfolio showcases the power of Turbo 8's View Transitions API with Rails. 
        Each navigation creates a seamless morphing experience with custom animations, 
        persistent elements, and smooth transitions between pages.
      </p>
    </div>
  </section>
</div>
